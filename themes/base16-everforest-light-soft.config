! Base16 Everforest Light (Soft)
! Scheme author: Márcio Sobel (https://github.com/marciosobel)
! Template author: Tinted Theming (https://github.com/tinted-theming)

! base00: #f3ead3
! base01: #eae4ca
! base02: #ddd8be
! base03: #939f91
! base04: #829181
! base05: #5c6a72
! base06: #4d5960
! base07: #333c43
! base08: #f85552
! base09: #f57d26
! base0A: #dfa000
! base0B: #8da101
! base0C: #35a77c
! base0D: #3a94c5
! base0E: #df69ba
! base0F: #829181

! Enable the extended coloring options
rofi.color-enabled: true

! Property Name     BG       Border   Separator
rofi.color-window:  #eae4ca, #eae4ca, #f3ead3

! Property Name     BG       FG       BG-alt   Head-BG  Head-FG
rofi.color-normal:  #eae4ca, #5c6a72, #eae4ca, #eae4ca, #333c43
rofi.color-active:  #eae4ca, #3a94c5, #eae4ca, #eae4ca, #3a94c5
rofi.color-urgent:  #eae4ca, #f85552, #eae4ca, #eae4ca, #f85552

! Set the desired separator style
rofi.separator-style: solid
