! Base16 Tinta
! Scheme author: Teshre
! Template author: Tinted Theming (https://github.com/tinted-theming)

! base00: #101012
! base01: #202023
! base02: #2c2c30
! base03: #62626a
! base04: #9d9c9d
! base05: #d8d6d0
! base06: #e3e1db
! base07: #eeece6
! base08: #d0726a
! base09: #e8843a
! base0A: #c8b86a
! base0B: #9aa890
! base0C: #80b8b4
! base0D: #8a9ab0
! base0E: #b0a0b8
! base0F: #4a4a50

! Enable the extended coloring options
rofi.color-enabled: true

! Property Name     BG       Border   Separator
rofi.color-window:  #202023, #202023, #101012

! Property Name     BG       FG       BG-alt   Head-BG  Head-FG
rofi.color-normal:  #202023, #d8d6d0, #202023, #202023, #eeece6
rofi.color-active:  #202023, #8a9ab0, #202023, #202023, #8a9ab0
rofi.color-urgent:  #202023, #d0726a, #202023, #202023, #d0726a

! Set the desired separator style
rofi.separator-style: solid
