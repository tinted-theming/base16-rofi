! Base16 Kissa Latte
! Scheme author: rwendell (https://github.com/rwendell/kissa)
! Template author: Tinted Theming (https://github.com/tinted-theming)

! base00: #f5f4f0
! base01: #e8e7e3
! base02: #d5d2cb
! base03: #91887d
! base04: #746c62
! base05: #1f1c16
! base06: #6e6459
! base07: #fefcfa
! base08: #9e3e3e
! base09: #8f5d22
! base0A: #7d6820
! base0B: #387050
! base0C: #287070
! base0D: #3468a8
! base0E: #6438a0
! base0F: #943a68

! Enable the extended coloring options
rofi.color-enabled: true

! Property Name     BG       Border   Separator
rofi.color-window:  #e8e7e3, #e8e7e3, #f5f4f0

! Property Name     BG       FG       BG-alt   Head-BG  Head-FG
rofi.color-normal:  #e8e7e3, #1f1c16, #e8e7e3, #e8e7e3, #fefcfa
rofi.color-active:  #e8e7e3, #3468a8, #e8e7e3, #e8e7e3, #3468a8
rofi.color-urgent:  #e8e7e3, #9e3e3e, #e8e7e3, #e8e7e3, #9e3e3e

! Set the desired separator style
rofi.separator-style: solid
