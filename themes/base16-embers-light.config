! Base16 Embers Light
! Scheme author: Jannik Siebert (https://github.com/janniks)
! Template author: Tinted Theming (https://github.com/tinted-theming)

! base00: #dbd6d1
! base01: #beb6ae
! base02: #a39a90
! base03: #8a8075
! base04: #5a5047
! base05: #433b32
! base06: #2c2620
! base07: #16130f
! base08: #826d57
! base09: #828257
! base0A: #6d8257
! base0B: #57826d
! base0C: #576d82
! base0D: #6d5782
! base0E: #82576d
! base0F: #825757

! Enable the extended coloring options
rofi.color-enabled: true

! Property Name     BG       Border   Separator
rofi.color-window:  #beb6ae, #beb6ae, #dbd6d1

! Property Name     BG       FG       BG-alt   Head-BG  Head-FG
rofi.color-normal:  #beb6ae, #433b32, #beb6ae, #beb6ae, #16130f
rofi.color-active:  #beb6ae, #6d5782, #beb6ae, #beb6ae, #6d5782
rofi.color-urgent:  #beb6ae, #826d57, #beb6ae, #beb6ae, #826d57

! Set the desired separator style
rofi.separator-style: solid
