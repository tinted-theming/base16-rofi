! Base16 Github Dark Dimmed
! Scheme author: Tinted Theming (https://github.com/tinted-theming)
! Template author: Tinted Theming (https://github.com/tinted-theming)

! base00: #22272e
! base01: #2d333b
! base02: #545d68
! base03: #636e7b
! base04: #768390
! base05: #adbac7
! base06: #cdd9e5
! base07: #ffffff
! base08: #f69d50
! base09: #6cb6ff
! base0A: #ae7c14
! base0B: #96d0ff
! base0C: #8ddb8c
! base0D: #dcbdfb
! base0E: #f47067
! base0F: #ff938a

! Enable the extended coloring options
rofi.color-enabled: true

! Property Name     BG       Border   Separator
rofi.color-window:  #2d333b, #2d333b, #22272e

! Property Name     BG       FG       BG-alt   Head-BG  Head-FG
rofi.color-normal:  #2d333b, #adbac7, #2d333b, #2d333b, #ffffff
rofi.color-active:  #2d333b, #dcbdfb, #2d333b, #2d333b, #dcbdfb
rofi.color-urgent:  #2d333b, #f69d50, #2d333b, #2d333b, #f69d50

! Set the desired separator style
rofi.separator-style: solid
