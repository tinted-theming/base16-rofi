! Base16 boo-shnickle-light
! Scheme author: boo-shnickle (@boo_shnickle)
! Template author: Tinted Theming (https://github.com/tinted-theming)

! base00: #ffffcc
! base01: #dedeb2
! base02: #bdbd97
! base03: #9c9c7d
! base04: #7c7c63
! base05: #5b5b49
! base06: #3a3a2e
! base07: #191914
! base08: #ffbfa5
! base09: #ffdc99
! base0A: #fff299
! base0B: #e7ff99
! base0C: #bfffc5
! base0D: #bfbfd9
! base0E: #f2bfd9
! base0F: #e5d6a6

! Enable the extended coloring options
rofi.color-enabled: true

! Property Name     BG       Border   Separator
rofi.color-window:  #dedeb2, #dedeb2, #ffffcc

! Property Name     BG       FG       BG-alt   Head-BG  Head-FG
rofi.color-normal:  #dedeb2, #5b5b49, #dedeb2, #dedeb2, #191914
rofi.color-active:  #dedeb2, #bfbfd9, #dedeb2, #dedeb2, #bfbfd9
rofi.color-urgent:  #dedeb2, #ffbfa5, #dedeb2, #dedeb2, #ffbfa5

! Set the desired separator style
rofi.separator-style: solid
