! Base16 Mezcal
! Scheme author: Teshre
! Template author: Tinted Theming (https://github.com/tinted-theming)

! base00: #13110e
! base01: #221f14
! base02: #36301e
! base03: #6e6450
! base04: #a79e8c
! base05: #e0d8c8
! base06: #e9e1cf
! base07: #f2ead6
! base08: #da6e54
! base09: #d9a441
! base0A: #d9a441
! base0B: #a8b84a
! base0C: #6fc8ae
! base0D: #8aa6c0
! base0E: #c28aa8
! base0F: #4e462c

! Enable the extended coloring options
rofi.color-enabled: true

! Property Name     BG       Border   Separator
rofi.color-window:  #221f14, #221f14, #13110e

! Property Name     BG       FG       BG-alt   Head-BG  Head-FG
rofi.color-normal:  #221f14, #e0d8c8, #221f14, #221f14, #f2ead6
rofi.color-active:  #221f14, #8aa6c0, #221f14, #221f14, #8aa6c0
rofi.color-urgent:  #221f14, #da6e54, #221f14, #221f14, #da6e54

! Set the desired separator style
rofi.separator-style: solid
